# =======================================
# CLEAN .HTACCESS FOR CODEIGNITER 3 (NO INDEX.PHP)
# =======================================

# Nonaktifkan tampilan direktori
Options -Indexes

# Aktifkan mod_rewrite
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Jika file atau folder tidak ditemukan
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Arahkan ke index.php tanpa menampilkan index.php di URL
  RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>

# Arahkan favicon
RewriteRule ^favicon\.ico$ /assets/images/favicon.ico [L]

# Tentukan versi PHP dari cPanel
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
